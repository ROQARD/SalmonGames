{
  "rewrites": [
    {
      "source": "/sys/:gameId/:path*",
      "destination": "https://html5.gamedistribution.com/:gameId/:path*"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Content-Security-Policy", "value": "frame-ancestors 'self' *" },
        { "key": "Referrer-Policy", "value": "no-referrer" }
      ]
    }
  ]
}
