{
  "rewrites": [
    {
      "source": "/api-proxy/:path*",
      "destination": "https://api.gamedistribution.com/:path*"
    },
    {
      "source": "/game-proxy/:path*",
      "destination": "https://html5.gamedistribution.com/:path*"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Referrer-Policy", "value": "no-referrer" }
      ]
    }
  ]
}
